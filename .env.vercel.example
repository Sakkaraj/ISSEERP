# Vercel production environment variables
# Copy these keys into: Vercel Project -> Settings -> Environment Variables

DB_HOST=YOUR_RAILWAY_HOST
DB_PORT=YOUR_RAILWAY_PORT
DB_USER=YOUR_RAILWAY_USER
DB_PASSWORD=YOUR_RAILWAY_PASSWORD
DB_NAME=YOUR_RAILWAY_DATABASE

# Use a long random secret in production
AUTH_TOKEN_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Required for production mode
NODE_ENV=production

# Optional (leave unset unless needed)
# FRONTEND_DEV_URL=
# PORT=
